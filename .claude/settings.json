{
  "statusLine": {
    "type": "command",
    "command": "bash /home/yoann/sources/banking/.claude/scripts/statusline.sh",
    "padding": 0
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/yoann/sources/banking/.claude/hooks/kanban-watch-write.sh 2>/dev/null || true",
            "statusMessage": "Checking kanban..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/yoann/sources/banking/.claude/hooks/kanban-watch-bash.sh 2>/dev/null || true",
            "statusMessage": "Checking kanban..."
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/yoann/sources/banking/.claude/hooks/agent-log.py 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reliever.example.com/process/CAP.BSP.004.ENV/CMD.BSP.004.ENV.RECALIBRATE_PERIOD_BUDGET/0.1.0/schema.json",
  "x-process-version": "0.1.0",
  "x-process-role": "command-payload",
  "x-process-capability": "CAP.BSP.004.ENV",
  "x-process-command": "CMD.BSP.004.ENV.RECALIBRATE_PERIOD_BUDGET",
  "x-process-aggregate": "AGG.BSP.004.ENV.PERIOD_BUDGET",
  "x-process-correlation-key": "case_id",
  "x-process-idempotency-key": "trigger.event_id",
  "title": "CMD.BSP.004.ENV.RECALIBRATE_PERIOD_BUDGET — Recalibrate the active period budget on tier upgrade",
  "description": "Payload of the RECALIBRATE_PERIOD_BUDGET command. Issued by POL.BSP.004.ENV.ON_TIER_UPGRADED on RVT.BSP.001.TIER_UPGRADE_RECORDED, handled by AGG.BSP.004.ENV.PERIOD_BUDGET. May emit RVT.BSP.004.ENVELOPE_INITIALIZED for newly added categories and RVT.BSP.004.ENVELOPE_CAP_REACHED when the new cap clamps to or below the already-consumed amount. Idempotent on trigger.event_id over a 30-day window.",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "period_index", "new_tier_snapshot", "trigger"],
  "$defs": {
    "category_allocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "cap_amount"],
      "properties": {
        "category": { "type": "string", "minLength": 1 },
        "cap_amount": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id"],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1,
          "description": "IDEMPOTENCY KEY. Identifier of the upstream tier-upgrade resource event."
        },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "properties": {
    "case_id": { "type": "string", "minLength": 1 },
    "period_index": {
      "type": "integer",
      "minimum": 0,
      "description": "The currently ACTIVE period_index of the case."
    },
    "new_tier_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier_id", "categories"],
      "description": "Snapshot of the NEW tier definition the beneficiary has just moved to.",
      "properties": {
        "tier_id": { "type": "string", "minLength": 1 },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/category_allocation" }
        }
      }
    },
    "trigger": { "$ref": "#/$defs/trigger" }
  }
}

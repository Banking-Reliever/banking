{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reliever.example.com/process/CAP.REF.001.BEN/CMD.REF.001.BEN.REGISTER_BENEFICIARY/0.1.0/schema.json",
  "x-process-version": "0.1.0",
  "x-process-role": "command-payload",
  "x-process-capability": "CAP.REF.001.BEN",
  "x-process-command": "CMD.REF.001.BEN.REGISTER_BENEFICIARY",
  "x-process-aggregate": "AGG.REF.001.BEN.BENEFICIARY_IDENTITY",
  "x-process-correlation-key": "external_id",
  "x-process-idempotency-key": "external_id",
  "title": "CMD.REF.001.BEN.REGISTER_BENEFICIARY — Register a new beneficiary in the canonical referential",
  "description": "Payload of the REGISTER_BENEFICIARY command. Issued by an HTTP API caller (typically the upstream eligibility/candidacy capability). Handled by AGG.REF.001.BEN.BENEFICIARY_IDENTITY. Emits one RVT.REF.001.BENEFICIARY_REFERENTIAL_UPDATED with transition_kind=REGISTERED. Idempotent on external_id over the lifetime of the case — re-calls return the existing internal_id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["external_id", "last_name", "first_name", "date_of_birth", "contact_details"],
  "$defs": {
    "contact_details": {
      "type": "object",
      "additionalProperties": false,
      "description": "Postal address and contact channels. Sticky-PII rule applies on UPDATE (INV.BEN.003).",
      "properties": {
        "postal_address": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "line1": { "type": "string", "minLength": 1 },
            "line2": { "type": "string" },
            "postal_code": { "type": "string", "minLength": 1 },
            "city": { "type": "string", "minLength": 1 },
            "country_code": { "type": "string", "minLength": 2, "maxLength": 2, "description": "ISO 3166-1 alpha-2." }
          },
          "required": ["line1", "postal_code", "city", "country_code"]
        },
        "email": { "type": "string", "format": "email" },
        "phone_number": {
          "type": "string",
          "description": "E.164 format recommended (e.g. +33612345678)."
        }
      }
    }
  },
  "properties": {
    "external_id": {
      "type": "string",
      "minLength": 1,
      "description": "IDEMPOTENCY KEY. External reference (e.g. candidacy / eligibility identifier) supplied by the caller. Must be unique per beneficiary."
    },
    "last_name": { "type": "string", "minLength": 1 },
    "first_name": { "type": "string", "minLength": 1 },
    "date_of_birth": { "type": "string", "format": "date" },
    "contact_details": { "$ref": "#/$defs/contact_details" }
  }
}
